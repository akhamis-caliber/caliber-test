# Caliber Backend Environment Variables Template
# Copy this file to .env and fill in your actual values

# Database Settings (currently using SQLite for development)
DATABASE_URL=sqlite:///./caliber.db
# For PostgreSQL: DATABASE_URL=postgresql://caliber_user:caliber_password@localhost:5432/caliber_db

# Redis Settings (optional for development)
REDIS_URL=redis://localhost:6379

# JWT Settings
JWT_SECRET_KEY=your-secret-key-here-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Firebase Settings (Required for authentication)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your-service-account%40your-project.iam.gserviceaccount.com

# OpenAI Settings (for AI features)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# Application Settings
SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=true
ENVIRONMENT=development

# File Storage Settings
STORAGE_PATH=./storage
MAX_FILE_SIZE=52428800
UPLOAD_FOLDER=uploads
PROCESSED_FOLDER=processed
REPORTS_FOLDER=reports

# Celery Settings (for background tasks)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS Settings
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]
CORS_ALLOW_CREDENTIALS=true 